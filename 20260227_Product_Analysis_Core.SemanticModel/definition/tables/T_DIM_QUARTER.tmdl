	column Quarter_IsInFinance
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: f7893728-c546-4161-988f-984aa73a2e58
		summarizeBy: none
		sourceColumn: Quarter_IsInFinance

		annotation SummarizationSetBy = Automatic

	partition T_DIM_QUARTER = m
		mode: import
		source =
				let
				    SalesQ = List.Distinct(List.Transform(T_FCT_SALES_A10P[QuarterStartDay], each Date.From(_))),
				    PromoQ = List.Distinct(List.Transform(T_FCT_PROMO_A10P_CD[QuarterStartDay], each Date.From(_))),
				    FinQ   = List.Distinct(List.Transform(T_FCT_FIN[QuarterStartDay], each Date.From(_))),
				
				    AllQ = List.Sort(List.Distinct(List.Combine({SalesQ, PromoQ, FinQ}))),
				
				    DimQ0 = Table.FromList(AllQ, Splitter.SplitByNothing(), {"QuarterStartDay"}),
				    DimQ1 = Table.TransformColumnTypes(DimQ0, {{"QuarterStartDay", type date}}),
				
				    AddYear = Table.AddColumn(DimQ1, "Year", each Date.Year([QuarterStartDay]), Int64.Type),
				    AddQNum = Table.AddColumn(AddYear, "QuarterNum", each Date.QuarterOfYear([QuarterStartDay]), Int64.Type),
				    AddQuarterKey = Table.AddColumn(AddQNum, "QuarterKey", each Text.From([Year]) & "Q" & Text.From([QuarterNum]), type text),
				    AddQuarterLabel = Table.AddColumn(AddQuarterKey, "QuarterLabel", each "Q" & Text.From([QuarterNum]) & " " & Text.From([Year]), type text),
				
				    IsInSales  = Table.AddColumn(AddQuarterLabel, "IsInSales", each List.Contains(SalesQ, [QuarterStartDay]), type logical),
				    IsInPromo  = Table.AddColumn(IsInSales, "IsInPromo", each List.Contains(PromoQ, [QuarterStartDay]), type logical),
				    IsInFinance = Table.AddColumn(IsInPromo, "IsInFinance", each List.Contains(FinQ, [QuarterStartDay]), type logical),
				    #"Renamed Columns" = Table.RenameColumns(IsInFinance,{{"IsInFinance", "Quarter_IsInFinance"}, {"IsInSales", "Quarter_IsInSales"}, {"IsInPromo", "Quarter_IsInPromo"}})
				in
				    #"Renamed Columns"

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Exception
