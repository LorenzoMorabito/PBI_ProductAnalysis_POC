	partition 'MOD Flex Flat Columns' = calculated
		mode: import
		source = ```
				VAR __Columns =
				{
				    ("Country", NAMEOF('T_DIM_COUNTRY'[Country]), 0),
				    ("Corporation", NAMEOF('T_DIM_CORPORATION'[Corporation]), 1),
				    ("Product", NAMEOF('T_DIM_PRODUCT'[Product]), 2),
				    ("Molecule", NAMEOF('T_DIM_MOLECULE'[MoleculeNorm]), 3),
				    ("Quarter", NAMEOF('T_DIM_QUARTER'[QuarterKey]), 4),
				    ("ATC4", NAMEOF('T_DIM_ACT4'[ATC4]), 5),
				    ("Sales Values", NAMEOF('MOD Flex Flat Inputs'[Flat Input Sales Values]), 6),
				    ("Sales Units", NAMEOF('MOD Flex Flat Inputs'[Flat Input Sales Units]), 7),
				    ("Counting Units", NAMEOF('MOD Flex Flat Inputs'[Flat Input Counting Units]), 8),
				    ("Promo Spend", NAMEOF('MOD Flex Flat Inputs'[Flat Input Promo Spend]), 9),
				    ("Promo Details", NAMEOF('MOD Flex Flat Inputs'[Flat Input Promo Details]), 10),
				    ("Promo Contacts", NAMEOF('MOD Flex Flat Inputs'[Flat Input Promo Contacts]), 11),
				    ("Promo Weighted Calls", NAMEOF('MOD Flex Flat Inputs'[Flat Input Promo Weighted Calls]), 12),
				    ("Fin ACT", NAMEOF('MOD Flex Flat Inputs'[Flat Input Fin ACT]), 13),
				    ("Fin BDG", NAMEOF('MOD Flex Flat Inputs'[Flat Input Fin BDG]), 14),
				    ("Fin ACT PY", NAMEOF('MOD Flex Flat Inputs'[Flat Input Fin ACT PY]), 15)
				}
				RETURN
				SELECTCOLUMNS(
				    __Columns,
				    "MOD Flex Flat Columns", [Value1],
				    "MOD Flex Flat Columns Fields", [Value2],
				    "MOD Flex Flat Columns Order", [Value3]
				)
				```
