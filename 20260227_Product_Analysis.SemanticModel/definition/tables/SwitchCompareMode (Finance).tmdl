		lineageTag: 7fd535aa-a1dd-4001-b89e-3b7db9739a9d

	column Compare
		lineageTag: 224ff488-55ec-420f-ac25-023c98beb4de
		summarizeBy: none
		isNameInferred
		sourceColumn: [Compare]

		annotation SummarizationSetBy = Automatic

	column Label
		lineageTag: ad21b794-cbbf-4e99-a9af-f1b9c05b864d
		summarizeBy: none
		isNameInferred
		sourceColumn: [Label]

		annotation SummarizationSetBy = Automatic

	partition 'SwitchCompareMode (Finance)' = calculated
