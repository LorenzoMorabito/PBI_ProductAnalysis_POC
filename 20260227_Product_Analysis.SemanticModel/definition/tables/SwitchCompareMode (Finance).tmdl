table 'SwitchCompareMode (Finance)'
	lineageTag: 69bb04df-c39c-421c-b27c-8ad77263cbc4

	measure 'Finance Compare (Selected)' =
			
			SWITCH(
			  SELECTEDVALUE('SwitchCompareMode (Finance)'[Compare], "vs BDG"),
			  "vs BDG", [Fin BDG],
			  "vs PY",  [Fin ACT PY]
			)
		lineageTag: 46aa2e92-8b5e-48ab-9fa2-cddfc9b07980

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Finance Compare Label (Selected)' =
			
