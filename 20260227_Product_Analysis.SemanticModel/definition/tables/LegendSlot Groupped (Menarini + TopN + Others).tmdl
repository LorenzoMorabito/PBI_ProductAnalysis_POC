	partition 'LegendSlot Groupped (Menarini + TopN + Others)' = calculated
		mode: import
		source =
				
				VAR MaxN = 10
				RETURN
				UNION(
				    ROW("Slot", "MENARINI", "SlotOrder", 0, "NIndex", 0),
				    SELECTCOLUMNS(
				        GENERATESERIES(1, MaxN, 1),
				        "Slot", "TOP " & [Value],
				        "SlotOrder", [Value],
				        "NIndex", [Value]
				    ),
				    ROW("Slot", "OTHERS", "SlotOrder", 999, "NIndex", 999)
				)

	annotation PBI_Id = 747e6b8a356b436bb3fdecc80977eb25

