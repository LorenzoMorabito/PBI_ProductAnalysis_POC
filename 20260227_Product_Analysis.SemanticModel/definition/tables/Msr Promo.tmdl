table 'Msr Promo'
	lineageTag: 3a8d131f-6dd4-420c-a86d-674324dcd0a4

	measure 'Promo Spend' =
			
			SUM ( T_FCT_PROMO_A10P_CD[Spending Total EUR] )
		formatString: 0
		lineageTag: c3330d88-8925-4f27-b285-10d38942adde

	measure 'Total Promo Spending €' =
			
			CALCULATE ( [Promo Spend], REMOVEFILTERS ( T_DIM_PRODUCT[Product] ) )
		formatString: 0
		lineageTag: ac0118d8-c148-4eb4-bd0f-6bfb20b2c564

	measure '% Share of Investments' =
			
			DIVIDE ( [Promo Spend], [Total Promo Spending €] )
		lineageTag: 82569e5f-8cd5-4b96-aedd-2359a4d66941

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Promo Details' =
			
			SUM ( T_FCT_PROMO_A10P_CD[Product Details] )
		formatString: 0
		lineageTag: 8648fb05-b527-43d1-bd7c-20c38537dd3d

	measure 'Market Promo Product Details' =
			
			CALCULATE ( [Promo Details], REMOVEFILTERS ( T_DIM_MOLECULE[MoleculeNorm] ), REMOVEFILTERS( T_DIM_CORPORATION[Corporation] ) )
		formatString: 0
		lineageTag: 153be49b-e0fd-41ba-a983-530a3c84f10a

	measure 'Promo SOV% (ATC4)' =
			
			DIVIDE ( [Promo Details], [Market Promo Product Details (ATC4)] )
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: b9240727-478d-4802-9f60-dbff322a0396

	measure 'Target Spend (Molecule)' =
			
			CALCULATE ( [Promo Spend], REMOVEFILTERS ( T_DIM_PRODUCT[Product] ) )
		lineageTag: 178b794a-cdf0-4652-a0fd-9272a150b267

	measure '% Share of Spend Target' =
			
			DIVIDE ( [Target Spend (Molecule)], [Market Spend (ATC4 - Total)] )
		lineageTag: 748eb95c-b109-40ac-ba0c-57b8c90f4ffc

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Target Contacts (Molecule)' =
			
			CALCULATE ( [Promo Contacts], REMOVEFILTERS ( T_DIM_PRODUCT[Product] ) )
		lineageTag: 79ecbf8e-16b1-4301-8e5d-654e88e89676

	measure 'Cost per Contact (Target)' =
			
			DIVIDE ( [Target Spend (Molecule)], [Target Contacts (Molecule)] )
		lineageTag: 76e703da-286f-4441-b926-97f1a6269d29

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Promo Contacts' = SUM(T_FCT_PROMO_A10P_CD[Contact Number])
		formatString: 0
		lineageTag: a98ecc87-5e62-4316-9e10-2c6ef5c16400

	measure 'Market Spend (ATC4 - Total)' =
			
			CALCULATE (
			    [Promo Spend],
			    REMOVEFILTERS ( T_DIM_PRODUCT[Product] ),
			    REMOVEFILTERS ( T_DIM_MOLECULE ),
			    REMOVEFILTERS ( T_FCT_PROMO_A10P_CD[Specialty] ),
			    REMOVEFILTERS ( T_FCT_PROMO_A10P_CD[Cam Channels] ),
			    REMOVEFILTERS ( T_FCT_PROMO_A10P_CD[Contact Type] )
			)
		formatString: 0
		lineageTag: 2c825b0e-52b4-4fe2-b6fb-60611cc1fd13

	measure 'Promo Spend €/1k Units' =
			
			DIVIDE ( [Market Spend (ATC4 - Total)], [Market Units] ) * 1000
		lineageTag: e73c5682-6e6c-4f76-9fd9-763f0e44f582

