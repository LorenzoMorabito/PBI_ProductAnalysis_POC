	measure 'Promo Spend €/1k Details (Median)' = ```
			
			VAR Base =
			    FILTER (
			        ADDCOLUMNS (
			            ALL ( T_DIM_MOLECULE[MoleculeNorm] ),
			            "x", CALCULATE ( [Promo Spend €/1k Details] )
			        ),
			        NOT ISBLANK ( [x] )
			    )
			RETURN
			PERCENTILEX.INC ( Base, [x], 0.5 )
			
			```
		lineageTag: c91739d5-cede-4d85-8138-78842c92a1d5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

