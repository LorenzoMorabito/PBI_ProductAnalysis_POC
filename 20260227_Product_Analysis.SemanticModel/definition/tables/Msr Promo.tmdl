	measure 'Promo SOV% EI vs PY (ATC4)' =
			
			VAR ms = [Promo SOV% (ATC4)]
			VAR ms_py = [Promo SOV% PY (ATC4)]
			RETURN IF( ISBLANK(ms_py), BLANK(), DIVIDE(ms, ms_py) * 100 )
		formatString: 0
		lineageTag: 738c6618-301e-48ca-8f70-d89a1a9d268d

		annotation PBI_FormatHint = {"isDecimal":true}

