	measure 'Sales Values MS% TopN Corp (Frequenze Cumulate)' = ```
			
			VAR N = [TopN Value]
			VAR TotalSales =
			    CALCULATE ( [LP Sales Values], ALL ( T_DIM_MOLECULE[MoleculeNorm] ), ALL( T_DIM_CORPORATION ) )
			VAR TopTable =
			    TOPN (
			        N,
			        ALL ( T_DIM_CORPORATION[Corporation] ),
			        CALCULATE ( [LP Sales Values] ),
			        DESC
			    )
			VAR TopSales =
			    SUMX ( TopTable, CALCULATE ( [LP Sales Values] ) )
			RETURN
			DIVIDE ( TopSales, TotalSales )
			
			```
		lineageTag: 20e7c414-3af0-49e8-9b36-35199a6dd1a1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'LP Promo Spend Δ% vs PY (QTR)' =
			
			VAR lp = [Last QuarterStartDay (stable)]
			RETURN
			CALCULATE(
			    [Promo Spend Δ% vs PY (QTR)],
			    REMOVEFILTERS(T_DIM_QUARTER),
			    T_DIM_QUARTER[QuarterStartDay] = lp
			)
		lineageTag: 1d7fde22-a781-4bf5-9932-ed7d243a4730

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Promo Weighted Calls' = SUM(T_FCT_PROMO_A10P_CD[Weighted Calls])
		formatString: #,0
