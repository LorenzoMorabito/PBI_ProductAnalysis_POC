		lineageTag: 841b3864-90fb-4d95-8381-50b2c2de5b27

	measure '% Share of Spend' = DIVIDE([Promo Spend], [Market Spend (ATC4 - Total)])
		lineageTag: 113afef0-38d5-4911-8f00-1f61d3320fb7

