	measure 'Market Units MAT (4Q)' =
			
			VAR AnchorQ = MAX ( T_DIM_QUARTER[QuarterStartDay] )
			
			VAR WindowQ =
			    TOPN (
			        4,
			        FILTER (
			            ALL ( T_DIM_QUARTER[QuarterStartDay] ),
			            T_DIM_QUARTER[QuarterStartDay] <= AnchorQ
			        ),
			        T_DIM_QUARTER[QuarterStartDay], DESC
			    )
			
			-- Conta quanti quarter nella finestra hanno un valore NON BLANK
			VAR QWithData =
			    COUNTROWS (
			        FILTER (
			            WindowQ,
			            VAR q = T_DIM_QUARTER[QuarterStartDay]
			            RETURN
			                NOT ISBLANK (
			                    CALCULATE (
			                        [Sales Units],
			                        REMOVEFILTERS ( T_DIM_QUARTER ),
			                        T_DIM_QUARTER[QuarterStartDay] = q
			                    )
			                )
			        )
			    )
			
			RETURN
			IF (
			    QWithData < 4,
			    BLANK(),
			    CALCULATE ( [Sales Units], REMOVEFILTERS ( T_DIM_QUARTER ), WindowQ )
			)
		lineageTag: 3ffd1a8b-516e-4cde-aa3c-5fbea7eb13a1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Market Units MAT PY (4Q)' =
			
			VAR AnchorQ = MAX ( T_DIM_QUARTER[QuarterStartDay] )
			VAR AnchorPY = EDATE ( AnchorQ, -12 )
			
			VAR WindowPY =
			    TOPN (
			        4,
			        FILTER (
			            ALL ( T_DIM_QUARTER[QuarterStartDay] ),
			            T_DIM_QUARTER[QuarterStartDay] <= AnchorPY
			        ),
			        T_DIM_QUARTER[QuarterStartDay], DESC
			    )
			
			VAR QWithDataPY =
			    COUNTROWS (
			        FILTER (
			            WindowPY,
			            VAR q = T_DIM_QUARTER[QuarterStartDay]
			            RETURN
			                NOT ISBLANK (
			                    CALCULATE (
			                        [Sales Units],
			                        REMOVEFILTERS ( T_DIM_QUARTER ),
			                        T_DIM_QUARTER[QuarterStartDay] = q
			                    )
			                )
			        )
			    )
			
			RETURN
			IF (
			    QWithDataPY < 4,
			    BLANK(),
			    CALCULATE ( [Sales Units], REMOVEFILTERS ( T_DIM_QUARTER ), WindowPY )
			)
		lineageTag: f40b9d93-f68f-4458-913e-e8ba9446ca5a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

