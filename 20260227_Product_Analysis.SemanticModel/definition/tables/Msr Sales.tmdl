	measure 'Sales Values (Target)' =
			
			VAR view = SELECTEDVALUE(Dim_Entity[ViewBy], "Molecule")
			VAR ent  = [Target Entity]
			RETURN
			IF(
			    ent = "(Seleziona...)",
			    BLANK(),
			    SWITCH(
			        view,
			        "Molecule",
			            CALCULATE(
			                [Sales Values],
			                TREATAS( {ent}, T_DIM_MOLECULE[MoleculeNorm] )
			            ),
			        "Corporation",
			            CALCULATE(
			                [Sales Values],
			                TREATAS( {ent}, T_DIM_CORPORATION[Corporation] )
			            )
			    )
			)
		lineageTag: 502ec24c-362d-435d-80cb-646e091bc5f1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Sales Values EI (base 100, vs PY)' =
			
			VAR ms = [Sales Values MS%]
			VAR ms_py = [Sales Values MS% PY]
			RETURN IF( ISBLANK(ms_py), BLANK(), DIVIDE(ms, ms_py) * 100 )
		lineageTag: 973a23ab-b18b-4f6a-b703-df3f90b87e25

