			VAR AnchorMonthPY = EDATE ( AnchorMonth, -12 )
			RETURN
			CALCULATE (
			    [Sales Units],
			    DATESINPERIOD ( T_DIM_MONTH[MonthStartDay], AnchorMonthPY, -3, MONTH )
