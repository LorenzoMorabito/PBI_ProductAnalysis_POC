			RETURN SelectedQ
		formatString: 0
		lineageTag: c65f812d-c718-49cb-95fb-92daa7189667

	measure 'Switch Sales Δ% vs PY (Colour)' = ```
			
			VAR ValoreAttuale = [MetricSales (Selected)] 
			VAR ValoreRiferimento = [MetricSales (Selected Period PY)]
			
			RETURN
			IF (
			    ValoreAttuale >= ValoreRiferimento,
			    "1",
			    "0"
			)
			```
		lineageTag: 5831700c-593d-4cd7-8a22-1f144c2ab3c0

