table SwitchPeriodMode
	lineageTag: fc07d8a8-6836-4573-aef1-4e7faa0b6c4c

	measure 'MetricSales (Selected Period)' =
			
			VAR SelectedQ = SELECTEDVALUE ( SwitchPeriodMode[Quarters], 1 )
			RETURN
			SWITCH(
			    TRUE(),
			    SelectedQ = 1, 'Msr Sales Switch'[Switch Sales Market],
			    SelectedQ > 1, [Switch Sales Market ROLLING (Dynamic)]
			)
		lineageTag: 65411cb9-9401-4b22-8750-6ec38ddc04e9

		annotation PBI_FormatHint = {"isGeneralNumber":true}

