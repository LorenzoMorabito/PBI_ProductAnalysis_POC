	measure 'Has PY' =
			
			NOT ISBLANK( [MetricSales (Selected Period PY)] )
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: f83694b5-9d10-49f0-9976-14b5d3b3d70c

	measure 'NumPeriodMAT (slected)' =
			
