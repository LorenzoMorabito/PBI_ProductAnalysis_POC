	measure 'Switch Sales Δ% vs PY (YoY)' =
			
			DIVIDE ( [MetricSales (Selected Period)] - [MetricSales (Selected Period PY)], [MetricSales (Selected Period PY)] )
		lineageTag: 2a6adb2a-6690-49f9-9a1c-9f717c4f2502

