model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: it-IT
	dataAccessOptions
		fastCombine
		legacyRedirects
		returnErrorValuesAsNull

queryGroup STG

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["T_FCT_FIN","T_FCT_PROMO_A10P_CD","T_FCT_SALES_A10P","T_DIM_COUNTRY","T_DIM_MOLECULE","T_DIM_ACT4","T_DIM_PRODUCT","T_DIM_MONTH","T_DIM_QUARTER","T_DIM_CORPORATION","T_DIM_SPECIALTY","T_DIM_CHANNELS","MOD Flex Table Inputs","MOD Flex Table Measure Selector","MOD Flex Table Axis","MOD Flex Table Metrics","MOD Flex Flat Inputs","MOD Flex Flat Dimensions","MOD Flex Flat Measures","root_path"]

annotation PBI_ProTooling = ["DaxQueryView_Desktop","DevMode"]

ref table T_FCT_FIN
ref table T_FCT_PROMO_A10P_CD
ref table T_FCT_SALES_A10P
ref table T_DIM_COUNTRY
ref table T_DIM_MOLECULE
ref table T_DIM_ACT4
ref table T_DIM_PRODUCT
ref table T_DIM_MONTH
ref table T_DIM_QUARTER
ref table T_DIM_CORPORATION
ref table T_DIM_SPECIALTY
ref table T_DIM_CHANNELS
ref table 'Msr Sales'
ref table 'Msr Promo'
ref table 'Msr Fin'
ref table 'MOD Flex Table Inputs'
ref table 'MOD Flex Table Measure Selector'
ref table 'MOD Flex Table Axis'
ref table 'MOD Flex Table Metrics'
ref table 'MOD Flex Flat Inputs'
ref table 'MOD Flex Flat Dimensions'
ref table 'MOD Flex Flat Measures'

ref cultureInfo en-US

