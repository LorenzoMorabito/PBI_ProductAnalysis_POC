{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/pbi-modular-platform/schemas/binding-profile.schema.v1.0.0.json",
  "title": "Power BI Module Binding Profile",
  "type": "object",
  "required": [
    "schemaVersion",
    "profileId",
    "moduleId",
    "savedAt",
    "resolvedMappings"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "profileId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "moduleId": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "domain": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "moduleVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "bindingMode": {
      "type": "string"
    },
    "savedAt": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "bindingSelections": {
      "type": "object"
    },
    "resolvedMappings": {
      "type": "object",
      "required": [
        "coreMeasures",
        "coreColumns"
      ],
      "properties": {
        "coreMeasures": {
          "type": "object"
        },
        "coreColumns": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
