{
  "moduleId": "flex_metrics_table_mvp",
  "version": "0.4.0",
  "domain": "marketing",
  "type": "semantic",
  "classification": "semantic-light",
  "dependencies": {
    "modules": [],
    "capabilities": []
  },
  "semanticImpact": "additive",
  "status": "prototype",
  "description": "Reusable pivot-style metrics table with collection-based dimension and metric binding.",
  "requires": {
    "coreMeasures": [],
    "coreColumns": []
  },
  "bindingContract": {
    "mode": "collection-guided",
    "collections": [
      {
        "id": "dimensions",
        "kind": "column",
        "label": "Dimensions",
        "description": "Choose the dimensions exposed by the pivot table.",
        "itemLabel": "Dimension",
        "minItems": 1,
        "maxItems": 6,
        "defaultVisibleCount": 1,
        "bindingKeyPrefix": "MOD_BIND_DIMENSION_",
        "bindingKeySuffix": "[Value]",
        "defaultItems": [
          {
            "label": "Dimension 1",
            "description": "Primary row dimension.",
            "defaultValue": "T_DIM_COUNTRY[Country]",
            "suggestions": ["Country", "Market", "Region"]
          },
          {
            "label": "Dimension 2",
            "description": "Secondary row dimension.",
            "defaultValue": "T_DIM_PRODUCT[Product]",
            "suggestions": ["Product", "Brand", "SKU"]
          },
          {
            "label": "Dimension 3",
            "description": "Additional row dimension.",
            "defaultValue": "T_DIM_CORPORATION[Corporation]",
            "suggestions": ["Corporation", "Company", "Business Unit"]
          },
          {
            "label": "Dimension 4",
            "description": "Additional row dimension.",
            "defaultValue": "T_DIM_MOLECULE[MoleculeNorm]",
            "suggestions": ["Molecule", "Ingredient", "Diagnosis"]
          },
          {
            "label": "Dimension 5",
            "description": "Additional row dimension.",
            "defaultValue": "T_DIM_QUARTER[QuarterKey]",
            "suggestions": ["Quarter", "Month", "Period"]
          },
          {
            "label": "Dimension 6",
            "description": "Additional row dimension.",
            "defaultValue": "T_DIM_ACT4[ATC4]",
            "suggestions": ["ATC4", "Class", "Segment"]
          }
        ]
      },
      {
        "id": "measures",
        "kind": "measure",
        "label": "Measures",
        "description": "Choose the metrics exposed by the pivot table.",
        "itemLabel": "Measure",
        "minItems": 1,
        "maxItems": 10,
        "defaultVisibleCount": 1,
        "bindingKeyPrefix": "MOD_BIND_MEASURE_",
        "defaultItems": [
          {
            "label": "Measure 1",
            "description": "Primary metric.",
            "defaultValue": "Sales Values",
            "suggestions": ["Sales Values", "Values", "Revenue", "Net Sales"]
          },
          {
            "label": "Measure 2",
            "description": "Secondary metric.",
            "defaultValue": "Sales Units",
            "suggestions": ["Sales Units", "Units", "Volume"]
          },
          {
            "label": "Measure 3",
            "description": "Additional metric.",
            "defaultValue": "Counting Units",
            "suggestions": ["Counting Units", "Count", "Transactions"]
          },
          {
            "label": "Measure 4",
            "description": "Additional metric.",
            "defaultValue": "Promo Spend",
            "suggestions": ["Promo Spend", "Spend", "Investment"]
          },
          {
            "label": "Measure 5",
            "description": "Additional metric.",
            "defaultValue": "Promo Details",
            "suggestions": ["Promo Details", "Details", "Detailing"]
          },
          {
            "label": "Measure 6",
            "description": "Additional metric.",
            "defaultValue": "Promo Contacts",
            "suggestions": ["Promo Contacts", "Contacts", "Calls"]
          },
          {
            "label": "Measure 7",
            "description": "Additional metric.",
            "defaultValue": "Promo Weighted Calls",
            "suggestions": ["Promo Weighted Calls", "Weighted Calls", "Weighted Contacts"]
          },
          {
            "label": "Measure 8",
            "description": "Additional metric.",
            "defaultValue": "Fin ACT",
            "suggestions": ["Fin ACT", "Actual", "ACT"]
          },
          {
            "label": "Measure 9",
            "description": "Additional metric.",
            "defaultValue": "Fin BDG",
            "suggestions": ["Fin BDG", "Budget", "BDG", "Target"]
          },
          {
            "label": "Measure 10",
            "description": "Additional metric.",
            "defaultValue": "Fin ACT PY",
            "suggestions": ["Fin ACT PY", "Previous Year", "PY", "Prior Year"]
          }
        ]
      }
    ]
  },
  "rendering": {
    "strategy": "flex-pivot"
  },
  "provides": {
    "semanticTables": [
      "MOD Flex Table Inputs",
      "MOD Flex Table Measure Selector",
      "MOD Flex Table Axis",
      "MOD Flex Table Metrics"
    ],
    "reportPage": {
      "name": "6f8d2c1e4b5a70918342",
      "displayName": "Flexible Metrics Pivot"
    }
  }
}
