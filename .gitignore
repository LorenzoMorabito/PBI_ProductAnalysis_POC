# Power BI Desktop local workspace artifacts
**/.pbi/

# Local source data and exploratory files are intentionally not versioned.
# Team policy is documented in docs/SETUP.md and docs/WORKFLOW.md.
/data_source/
/xml_oas/
/databricks-catalog-assessment/

# Repo health generated outputs are runtime artifacts and should not be committed.
/repository-health/outputs/current/*
!/repository-health/outputs/current/.gitkeep
/repository-health/outputs/history/*
!/repository-health/outputs/history/.gitkeep
