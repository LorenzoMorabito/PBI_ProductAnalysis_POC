	column Column
		isHidden
		formatString: 0
		lineageTag: 672dc9cf-c20e-44e2-b4d7-19817fb4e819
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Column]

		annotation SummarizationSetBy = Automatic

	partition Promo = calculated
		mode: import
		source = Row("Column", BLANK())

