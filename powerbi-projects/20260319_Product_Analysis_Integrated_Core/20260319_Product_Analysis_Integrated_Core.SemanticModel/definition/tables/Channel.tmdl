	partition Channel = m
		mode: import
		source =
				let
				    Source = Csv.Document(File.Contents(root_path & "dim_channel.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
				    #"Promoted Headers" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
