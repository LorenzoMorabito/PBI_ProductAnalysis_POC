	measure 'Units MS%' =
			
			VAR Atc4Scope = VALUES ( Portfolio[ATC4 Code] )
			VAR MarketUnits =
			    CALCULATE (
			        [Units],
			        REMOVEFILTERS ( Portfolio ),
			        REMOVEFILTERS ( 'Sales Product' ),
			        KEEPFILTERS ( Atc4Scope )
			    )
			RETURN
			    DIVIDE ( [Units], MarketUnits )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Share
		lineageTag: 0d95de27-804a-4fe8-a9cc-405743e089c8

	measure 'Values MS%' =
			
			VAR Atc4Scope = VALUES ( Portfolio[ATC4 Code] )
			VAR MarketValues =
			    CALCULATE (
			        [Values],
			        REMOVEFILTERS ( Portfolio ),
			        REMOVEFILTERS ( 'Sales Product' ),
			        KEEPFILTERS ( Atc4Scope )
			    )
			RETURN
			    DIVIDE ( [Values], MarketValues )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Share
		lineageTag: 362adcb9-6c5f-4e0f-8d43-34a3ac33b770

	measure 'Units EI' =
			
			VAR CurrentShare = [Units MS%]
			VAR PreviousShare =
			    CALCULATE ( [Units MS%], DATEADD ( Quarter[Quarter Date], -1, YEAR ) )
			RETURN
			    IF ( ISBLANK ( PreviousShare ), BLANK (), DIVIDE ( CurrentShare, PreviousShare ) * 100 )
		formatString: 0.0;-0.0;0.0
		displayFolder: Share
		lineageTag: 1b0f698a-a6cf-4e9c-9778-8ee5a28b5268

	measure 'Values EI' =
			
			VAR CurrentShare = [Values MS%]
			VAR PreviousShare =
			    CALCULATE ( [Values MS%], DATEADD ( Quarter[Quarter Date], -1, YEAR ) )
			RETURN
			    IF ( ISBLANK ( PreviousShare ), BLANK (), DIVIDE ( CurrentShare, PreviousShare ) * 100 )
		formatString: 0.0;-0.0;0.0
		displayFolder: Share
		lineageTag: 528ca2df-1549-4f94-9cc8-b0a2a996ab11

	measure 'Units +/-% vs PY' =
			
			VAR PreviousValue =
			    CALCULATE ( [Units], DATEADD ( Quarter[Quarter Date], -1, YEAR ) )
			RETURN
			    DIVIDE ( [Units] - PreviousValue, PreviousValue )
		formatString: 0.0%;-0.0%;0.0%
