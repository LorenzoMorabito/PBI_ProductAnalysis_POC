	measure 'Units MAT +/-% vs PY' =
			
			VAR AnchorQ = MAX ( Quarter[Quarter Date] )
			VAR AnchorPY = EDATE ( AnchorQ, -12 )
			VAR WindowPY =
			    TOPN (
			        4,
			        FILTER (
			            ALL ( Quarter[Quarter Date] ),
			            Quarter[Quarter Date] <= AnchorPY
			        ),
			        Quarter[Quarter Date], DESC
			    )
			VAR QWithDataPY =
			    COUNTROWS (
			        FILTER (
			            WindowPY,
			            VAR q = Quarter[Quarter Date]
			            RETURN
			                NOT ISBLANK (
			                    CALCULATE (
			                        [Units],
			                        REMOVEFILTERS ( Quarter ),
			                        Quarter[Quarter Date] = q
			                    )
			                )
			        )
			    )
			VAR PreviousValue =
			    IF (
			        QWithDataPY < 4,
			        BLANK (),
			        CALCULATE ( [Units], REMOVEFILTERS ( Quarter ), WindowPY )
			    )
			RETURN
			    DIVIDE ( [Units MAT] - PreviousValue, PreviousValue )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: MAT
		lineageTag: 32d262d1-b8bb-4178-9f42-9e5c1b508eea

