model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: it-IT
	dataAccessOptions
		fastCombine
		legacyRedirects
		returnErrorValuesAsNull

queryGroup STG

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["F_Sales","F_Promo","F_Finance","Country","Quarter","Month","Portfolio","Molecule","B_PortfolioMolecule","Sales Product","Promo Product","Finance Product","Sector","Diagnosis","Specialty","Channel","Feedback","root_path"]

annotation PBI_ProTooling = ["DaxQueryView_Desktop","DevMode"]

ref table Country
ref table Quarter
ref table Month
ref table Portfolio
ref table Molecule
ref table B_PortfolioMolecule
ref table 'Sales Product'
ref table 'Promo Product'
ref table 'Finance Product'
ref table F_Sales
ref table F_Promo
ref table F_Finance
ref table Sector
ref table Diagnosis
ref table Specialty
ref table Channel
ref table Feedback
ref table Sales
ref table Promo
ref table Finance

ref cultureInfo en-US

