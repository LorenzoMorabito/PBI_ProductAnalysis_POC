model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: it-IT
	dataAccessOptions
		fastCombine
		legacyRedirects
		returnErrorValuesAsNull

queryGroup STG

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["F_Finance","Country","Month","Product","Molecule","B_ProductMolecule","root_path"]

annotation PBI_ProTooling = ["DaxQueryView_Desktop","DevMode"]

ref table F_Finance
ref table Country
ref table Month
ref table Product
ref table Molecule
ref table B_ProductMolecule
ref table Finance

ref cultureInfo en-US

