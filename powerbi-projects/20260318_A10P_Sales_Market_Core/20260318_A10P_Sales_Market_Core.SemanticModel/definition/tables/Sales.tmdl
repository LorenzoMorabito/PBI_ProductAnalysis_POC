	measure 'Units MAT' =
			
			VAR AnchorQ = MAX ( Quarter[Quarter Date] )
			VAR WindowQ =
			    TOPN (
			        4,
			        FILTER (
			            ALL ( Quarter[Quarter Date] ),
			            Quarter[Quarter Date] <= AnchorQ
			        ),
			        Quarter[Quarter Date], DESC
			    )
			VAR QWithData =
			    COUNTROWS (
			        FILTER (
			            WindowQ,
			            VAR q = Quarter[Quarter Date]
			            RETURN
			                NOT ISBLANK (
			                    CALCULATE (
			                        [Units],
			                        REMOVEFILTERS ( Quarter ),
			                        Quarter[Quarter Date] = q
			                    )
			                )
			        )
			    )
			RETURN
			    IF (
			        QWithData < 4,
			        BLANK (),
			        CALCULATE ( [Units], REMOVEFILTERS ( Quarter ), WindowQ )
			    )
		formatString: #,0;-#,0;0
		displayFolder: MAT
		lineageTag: fba1e6bc-26f1-4011-a560-926fac30011a

	measure 'Values MAT' =
			
