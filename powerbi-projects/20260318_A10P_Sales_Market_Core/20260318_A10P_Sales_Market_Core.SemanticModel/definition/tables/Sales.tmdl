	measure 'Units MS%' =
			
			VAR Atc4Scope = VALUES ( Product[ATC4 Code] )
			VAR MarketUnits =
			    CALCULATE (
			        [Units],
			        REMOVEFILTERS ( Product ),
			        KEEPFILTERS ( Atc4Scope )
			    )
			RETURN
			    DIVIDE ( [Units], MarketUnits )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Share
		lineageTag: 428a8c2a-edbb-47f2-8ee8-6e009704fbc0

	measure 'Values MS%' =
			
			VAR Atc4Scope = VALUES ( Product[ATC4 Code] )
			VAR MarketValues =
			    CALCULATE (
			        [Values],
			        REMOVEFILTERS ( Product ),
			        KEEPFILTERS ( Atc4Scope )
			    )
			RETURN
			    DIVIDE ( [Values], MarketValues )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Share
		lineageTag: 2031b063-a827-4422-b6fb-1e3ed3680134

	measure 'Units EI' =
			
			VAR CurrentShare = [Units MS%]
			VAR PreviousShare =
			    CALCULATE ( [Units MS%], DATEADD ( Quarter[Quarter Date], -1, YEAR ) )
			RETURN
			    IF ( ISBLANK ( PreviousShare ), BLANK (), DIVIDE ( CurrentShare, PreviousShare ) * 100 )
		formatString: 0.0;-0.0;0.0
		displayFolder: Share
		lineageTag: a970b5bc-800b-4b56-9700-60d32dd98361

	measure 'Values EI' =
			
			VAR CurrentShare = [Values MS%]
			VAR PreviousShare =
			    CALCULATE ( [Values MS%], DATEADD ( Quarter[Quarter Date], -1, YEAR ) )
			RETURN
			    IF ( ISBLANK ( PreviousShare ), BLANK (), DIVIDE ( CurrentShare, PreviousShare ) * 100 )
		formatString: 0.0;-0.0;0.0
		displayFolder: Share
		lineageTag: e66be129-3028-49d9-917b-6af1af9dac46

	measure 'Units +/-% vs PY' =
			
			VAR PreviousValue =
			    CALCULATE ( [Units], DATEADD ( Quarter[Quarter Date], -1, YEAR ) )
			RETURN
			    DIVIDE ( [Units] - PreviousValue, PreviousValue )
		formatString: 0.0%;-0.0%;0.0%
