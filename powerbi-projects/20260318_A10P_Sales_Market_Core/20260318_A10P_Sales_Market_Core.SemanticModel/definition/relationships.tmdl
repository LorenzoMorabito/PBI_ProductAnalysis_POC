relationship REL_BRIDGE_PRODUCT
	crossFilteringBehavior: bothDirections
	fromColumn: B_ProductMolecule.'Product Key'
	toColumn: Product.'Product Key'

relationship REL_BRIDGE_MOLECULE
	crossFilteringBehavior: bothDirections
	fromColumn: B_ProductMolecule.'Molecule Key'
	toColumn: Molecule.'Molecule Key'

relationship REL_SALES_COUNTRY
	fromColumn: F_Sales.'Country Key'
	toColumn: Country.'Country Key'

relationship REL_SALES_SECTOR
	fromColumn: F_Sales.'Sector Key'
	toColumn: Sector.'Sector Key'

relationship REL_SALES_QUARTER
	fromColumn: F_Sales.'Quarter Key'
	toColumn: Quarter.'Quarter Key'

relationship REL_SALES_DIAGNOSIS
	fromColumn: F_Sales.'Diagnosis Key'
	toColumn: Diagnosis.'Diagnosis Key'

relationship REL_SALES_PRODUCT
	fromColumn: F_Sales.'Product Key'
	toColumn: Product.'Product Key'

