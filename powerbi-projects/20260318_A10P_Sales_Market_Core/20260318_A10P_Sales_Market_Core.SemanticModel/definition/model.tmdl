model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: it-IT
	dataAccessOptions
		fastCombine
		legacyRedirects
		returnErrorValuesAsNull

queryGroup STG

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["F_Sales","Country","Sector","Quarter","Diagnosis","Product","Molecule","B_ProductMolecule","root_path"]

annotation PBI_ProTooling = ["DaxQueryView_Desktop","DevMode"]

ref table Country
ref table Product
ref table Molecule
ref table B_ProductMolecule
ref table F_Sales
ref table Sector
ref table Quarter
ref table Diagnosis
ref table Sales

ref cultureInfo en-US

