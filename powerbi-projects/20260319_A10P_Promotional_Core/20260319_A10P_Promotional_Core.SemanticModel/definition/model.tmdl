model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: it-IT
	dataAccessOptions
		fastCombine
		legacyRedirects
		returnErrorValuesAsNull

queryGroup STG

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["F_Promo","Country","Quarter","Product","Molecule","B_ProductMolecule","Specialty","Channel","Feedback","root_path"]

annotation PBI_ProTooling = ["DaxQueryView_Desktop","DevMode"]

ref table Country
ref table Quarter
ref table Product
ref table Molecule
ref table B_ProductMolecule
ref table Specialty
ref table Channel
ref table Feedback
ref table F_Promo
ref table Promo

ref cultureInfo en-US

