	measure 'Switch Sales Market MAT (4Q)' = ```
			
			VAR AnchorQ = MAX ( T_DIM_QUARTER[QuarterStartDay] )
			
			VAR WindowQ =
			    TOPN (
			        4,
			        FILTER (
			            ALL ( T_DIM_QUARTER[QuarterStartDay] ),
			            T_DIM_QUARTER[QuarterStartDay] <= AnchorQ
			        ),
			        T_DIM_QUARTER[QuarterStartDay], DESC
			    )
			
			VAR QWithData =
			    COUNTROWS (
			        FILTER (
			            WindowQ,
			            VAR q = T_DIM_QUARTER[QuarterStartDay]
			            RETURN
			                NOT ISBLANK (
			                    CALCULATE (
			                        [MetricSales (Selected)],
			                        REMOVEFILTERS ( T_DIM_QUARTER ),
			                        T_DIM_QUARTER[QuarterStartDay] = q
			                    )
			                )
			        )
			    )
			
			RETURN
			IF (
			    QWithData < 4,
			    BLANK(),
			    CALCULATE ( [MetricSales (Selected)], REMOVEFILTERS ( T_DIM_QUARTER ), WindowQ )
			)
			
			```
		lineageTag: 80dee182-849d-4d99-aae8-cf7730cc6a44

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Switch Sales Market MAT PY (4Q)' =
			
			VAR AnchorQ = MAX ( T_DIM_QUARTER[QuarterStartDay] )
			VAR AnchorPY = EDATE ( AnchorQ, -12 )
			
			VAR WindowPY =
			    TOPN (
			        4,
			        FILTER (
			            ALL ( T_DIM_QUARTER[QuarterStartDay] ),
			            T_DIM_QUARTER[QuarterStartDay] <= AnchorPY
			        ),
			        T_DIM_QUARTER[QuarterStartDay], DESC
			    )
			
			VAR QWithDataPY =
			    COUNTROWS (
			        FILTER (
			            WindowPY,
			            VAR q = T_DIM_QUARTER[QuarterStartDay]
			            RETURN
			                NOT ISBLANK (
			                    CALCULATE (
			                        [MetricSales (Selected)],
			                        REMOVEFILTERS ( T_DIM_QUARTER ),
			                        T_DIM_QUARTER[QuarterStartDay] = q
			                    )
			                )
			        )
			    )
			
			RETURN
			IF (
			    QWithDataPY < 4,
			    BLANK(),
			    CALCULATE ( [MetricSales (Selected)], REMOVEFILTERS ( T_DIM_QUARTER ), WindowPY )
			)
		lineageTag: b72f1ccc-7869-406e-b999-228406158396

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Switch Sales Measure (Last Period)' =
			
			VAR lp = [Last QuarterStartDay (stable)]
			RETURN
			CALCULATE(
			    [MetricSales (Selected)],
			    REMOVEFILTERS(T_DIM_QUARTER),
			    T_DIM_QUARTER[QuarterStartDay] = lp
			)
		lineageTag: 226990cb-f596-41e9-bfe2-de7a6d470b60

