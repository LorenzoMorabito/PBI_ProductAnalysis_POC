	measure 'Switch Sales Market ROLLING (Dynamic)' =
			
			VAR AnchorQ = MAX ( T_DIM_QUARTER[QuarterStartDay] )
			VAR PeriodSelectedQ = SELECTEDVALUE ( SwitchPeriodMode[Quarters], 4 )
			VAR WindowQ =
			    TOPN (
			        PeriodSelectedQ,
			        FILTER (
			            ALL ( T_DIM_QUARTER[QuarterStartDay] ),
			            T_DIM_QUARTER[QuarterStartDay] <= AnchorQ
			        ),
			        T_DIM_QUARTER[QuarterStartDay], DESC
			    )
			
			VAR QWithData =
			    COUNTROWS (
			        FILTER (
			            WindowQ,
			            VAR q = T_DIM_QUARTER[QuarterStartDay]
			            RETURN
			                NOT ISBLANK (
			                    CALCULATE (
			                        [MetricSales (Selected)],
			                        REMOVEFILTERS ( T_DIM_QUARTER ),
			                        T_DIM_QUARTER[QuarterStartDay] = q
			                    )
			                )
			        )
			    )
			
			RETURN
			IF (
			    QWithData < PeriodSelectedQ,
			    BLANK(),
			    CALCULATE ( [MetricSales (Selected)], REMOVEFILTERS ( T_DIM_QUARTER ), WindowQ )
			)
		lineageTag: c2dcc3b3-15d3-467f-ba54-193a7e0522b8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Switch Sales Market ROLLING PY (Dynamic)' =
			
			VAR PeriodSelectedQ = SELECTEDVALUE ( SwitchPeriodMode[Quarters], 4 )
			VAR AnchorQ         = MAX ( T_DIM_QUARTER[QuarterStartDay] )
			VAR AnchorPY        = EDATE ( AnchorQ, -12 )
			
			VAR WindowPY =
			    TOPN (
			        PeriodSelectedQ,
			        FILTER (
			            ALL ( T_DIM_QUARTER[QuarterStartDay] ),
			            T_DIM_QUARTER[QuarterStartDay] <= AnchorPY
			        ),
			        T_DIM_QUARTER[QuarterStartDay], DESC
			    )
			
			VAR HasFullWindow = COUNTROWS ( WindowPY ) = PeriodSelectedQ
			
			VAR QWithDataPY =
			    COUNTROWS (
			        FILTER (
			            WindowPY,
			            VAR q = T_DIM_QUARTER[QuarterStartDay]
			            RETURN
			                NOT ISBLANK (
			                    CALCULATE (
			                        [MetricSales (Selected)],
			                        REMOVEFILTERS ( T_DIM_QUARTER ),
			                        T_DIM_QUARTER[QuarterStartDay] = q
			                    )
			                )
			        )
			    )
			
			RETURN
			IF (
			    NOT HasFullWindow || QWithDataPY < PeriodSelectedQ,
			    BLANK(),
			    CALCULATE ( [MetricSales (Selected)], REMOVEFILTERS ( T_DIM_QUARTER ), WindowPY )
			)
		lineageTag: ed90d636-24b1-4d60-a392-49f0f66a3e00

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Switch MENARINI LP PY' =
			
			VAR lp = [Last QuarterStartDay (stable)]
			VAR lp_py_date = EDATE(lp, -12)
			VAR lp_py =
			    CALCULATE(
			        MAX(T_DIM_QUARTER[QuarterStartDay]),
			        FILTER(
			            ALL(T_DIM_QUARTER[QuarterStartDay]),
			            T_DIM_QUARTER[QuarterStartDay] <= lp_py_date
			        )
			    )
			RETURN
			CALCULATE(
			    [MetricSales (Selected)],
			    REMOVEFILTERS(T_DIM_QUARTER),
			    T_DIM_QUARTER[QuarterStartDay] = lp_py,
			    T_DIM_CORPORATION[Corporation] = "MENARINI"
			)
		lineageTag: ceffba67-d6fd-4f99-937d-ec8f26bef788

