	measure 'Switch Sales Market Δ% vs PY (MAT)' =
			
			DIVIDE ( [Switch Sales Market MAT (4Q)] - [Switch Sales Market MAT PY (4Q)], [Switch Sales Market MAT PY (4Q)] )
		lineageTag: 53eaa3fe-065c-4c43-a0ee-7aef8714ad7b

