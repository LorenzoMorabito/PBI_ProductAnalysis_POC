	measure 'Switch Sales Measure (Last Period PY)' =
			
			VAR lp = [Last QuarterStartDay (stable)]
			VAR lp_py_date = EDATE(lp, -12)
			VAR lp_py =
			    CALCULATE(
			        MAX(T_DIM_QUARTER[QuarterStartDay]),
			        FILTER(
			            ALL(T_DIM_QUARTER[QuarterStartDay]),
			            T_DIM_QUARTER[QuarterStartDay] <= lp_py_date
			        )
			    )
			RETURN
			CALCULATE(
			    [MetricSales (Selected)],
			    REMOVEFILTERS(T_DIM_QUARTER),
			    T_DIM_QUARTER[QuarterStartDay] = lp_py
			)
		lineageTag: 472f2072-1224-4bae-b087-89f6227e6e3e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

