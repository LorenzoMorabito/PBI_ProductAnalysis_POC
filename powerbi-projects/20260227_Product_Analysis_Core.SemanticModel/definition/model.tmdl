model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: it-IT
	dataAccessOptions
		fastCombine
		legacyRedirects
		returnErrorValuesAsNull

queryGroup STG

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["T_FCT_FIN","T_FCT_PROMO_A10P_CD","T_FCT_SALES_A10P","T_DIM_COUNTRY","T_DIM_MOLECULE","T_DIM_ACT4","T_DIM_PRODUCT","T_DIM_MONTH","T_DIM_QUARTER","T_DIM_CORPORATION","T_DIM_SPECIALTY","T_DIM_CHANNELS","root_path"]

annotation PBI_ProTooling = ["DaxQueryView_Desktop","DevMode"]

ref table T_FCT_FIN
ref table T_FCT_PROMO_A10P_CD
ref table T_FCT_SALES_A10P
ref table T_DIM_COUNTRY
ref table T_DIM_MOLECULE
ref table T_DIM_ACT4
ref table T_DIM_PRODUCT
ref table T_DIM_MONTH
ref table T_DIM_QUARTER
ref table T_DIM_CORPORATION
ref table T_DIM_SPECIALTY
ref table T_DIM_CHANNELS
ref table 'Msr Sales'
ref table 'Msr Promo'
ref table 'Msr Fin'

ref cultureInfo en-US

