	column Column
		isHidden
		formatString: 0
		lineageTag: 4937cf68-1569-40a6-9115-66a074e84475
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Column]

		annotation SummarizationSetBy = Automatic

	partition Promo = calculated
		mode: import
		source = Row("Column", BLANK())

